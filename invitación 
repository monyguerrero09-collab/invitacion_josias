<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Gran Carrera de Cumpleaños – Josías</title>

<style>
:root{
  --rojo:#e10600;
  --amarillo:#ffd000;
  --negro:#0b0b0b;
  --blanco:#ffffff;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family: "Segoe UI", Arial, sans-serif;
  background: radial-gradient(circle at 50% -20%, #ff3b3b 0%, var(--rojo) 40%, #1a0000 100%);
  color:var(--blanco);
  text-align:center;
  overflow-x:hidden;
}

.header{
  padding:40px 20px 10px;
}

.header h1{
  margin:0;
  font-size:48px;
}

.header h2{
  margin:10px 0 0;
  font-size:34px;
  color:var(--amarillo);
}

.track{
  position:relative;
  margin:30px auto;
  width:90%;
  max-width:900px;
  height:120px;
  background:#222;
  border-radius:60px;
  overflow:hidden;
}

.track::before{
  content:"";
  position:absolute;
  left:0;
  top:50%;
  width:200%;
  height:6px;
  transform:translateY(-50%);
  background: repeating-linear-gradient(
    90deg,
    transparent 0 40px,
    var(--amarillo) 40px 80px
  );
  animation:moveRoad 2s linear infinite;
}

.car{
  position:absolute;
  top:50%;
  left:-120px;
  transform:translateY(-50%);
  font-size:70px;
  animation:drive 6s linear infinite;
}

.card{
  width:90%;
  max-width:700px;
  margin:20px auto 40px;
  padding:25px 20px 30px;
  background:rgba(0,0,0,.45);
  border-radius:18px;
}

.foto{
  width:180px;
  height:180px;
  object-fit:cover;
  border-radius:50%;
  border:6px solid var(--amarillo);
  margin-bottom:15px;
}

.info{
  font-size:22px;
  margin:6px 0;
}

#contador{
  margin:15px 0 20px;
  font-size:24px;
  color:var(--amarillo);
  font-weight:600;
}

.buttons{
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
  gap:12px;
}

.btn{
  border:none;
  border-radius:12px;
  padding:14px 22px;
  font-size:18px;
  cursor:pointer;
}

.whatsapp{background:#25D366;color:white}
.map{background:#4285F4;color:white}
.music{background:#ffae00;color:black}

@keyframes drive{
  0%{left:-120px}
  100%{left:100%}
}

@keyframes moveRoad{
  0%{transform:translate(-50%,-50%)}
  100%{transform:translate(0,-50%)}
}

.confetti{
  position:fixed;
  width:8px;
  height:8px;
  background:yellow;
  top:-10px;
  animation:fall linear forwards;
}

@keyframes fall{
  to{
    transform:translateY(110vh) rotate(720deg);
    opacity:0;
  }
}
</style>
</head>

<body>

<div class="header">
  <h1>🏁 ¡Gran Carrera de Cumpleaños!</h1>
  <h2>Josías cumple 3 años 🏎️</h2>
</div>

<div class="track">
  <div class="car">🏎️</div>
</div>

<div class="card">

  <!-- FOTO -->
  <img src="FOTO_JOSIAS_URL" class="foto">

  <div class="info">📅 11 de abril de 2026</div>
  <div class="info">⏰ 4:00 PM</div>
  <div class="info">📍 Guadalupe Primero, Querétaro</div>

  <div id="contador"></div>

  <div class="buttons">
    <button class="btn whatsapp" onclick="confirmar()">Confirmar asistencia</button>
    <button class="btn map" onclick="ubicacion()">Ver ubicación</button>
    <button class="btn music" onclick="toggleMusic()">🎵 Música</button>
  </div>

</div>

<audio id="musica" loop>
<source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
</audio>

<script>

const fecha = new Date("Apr 11, 2026 16:00:00").getTime();

setInterval(()=>{
  const ahora = new Date().getTime();
  const d = fecha - ahora;

  const dias=Math.floor(d/(1000*60*60*24));
  const horas=Math.floor((d%(1000*60*60*24))/(1000*60*60));
  const min=Math.floor((d%(1000*60*60))/(1000*60));
  const seg=Math.floor((d%(1000*60))/1000);

  document.getElementById("contador").innerHTML =
  "⏳ Faltan "+dias+" días "+horas+"h "+min+"m "+seg+"s";
},1000);

function confirmar(){
  window.open("https://wa.me/524424069757?text=Confirmo%20mi%20asistencia%20al%20cumpleaños%20de%20Josías%20🏎️🎉");
}

function ubicacion(){
  window.open("https://maps.google.com/?q=20.483089,-100.302696");
}

const musica=document.getElementById("musica");
function toggleMusic(){
  if(musica.paused){musica.play();}
  else{musica.pause();}
}

function lanzarConfeti(){
  for(let i=0;i<25;i++){
    const c=document.createElement("div");
    c.className="confetti";
    c.style.left=Math.random()*100+"vw";
    c.style.animationDuration=(2+Math.random()*3)+"s";
    document.body.appendChild(c);
    setTimeout(()=>c.remove(),5000);
  }
}

setInterval(lanzarConfeti,3000);

</script>

</body>
</html>